+                        </td>
+
+                        <td className="muted">{fmtDate(r.updatedAt)}</td>
+
+                        <td style={{ textAlign: "right" }}>
+                          <div className="x-row x-row-wrap" style={{ justifyContent: "flex-end", gap: 8 }}>
