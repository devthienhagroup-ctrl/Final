 function inRange(price: number, r: PriceRange) {
   if (r === "all") return true;
   if (r === "lt200") return price < 200_000;
   if (r === "200-400") return price >= 200_000 && price <= 400_000;
   if (r === "gt400") return price > 400_000;
   return true;
 }
 
