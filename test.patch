+import { Type } from 'class-transformer'
+import { IsIn, IsInt, IsOptional, IsString, MaxLength, Min } from 'class-validator'
+
+export class AdminListUsersQueryDto {
+  @IsOptional()
+  @IsString()
+  @MaxLength(255)
+  q?: string
+
+  @IsOptional()
+  @IsString()
+  @IsIn(['ACTIVE', 'INACTIVE'])
+  status?: 'ACTIVE' | 'INACTIVE'
+
+  @IsOptional()
+  @Type(() => Number)
+  @IsInt()
+  @Min(1)
+  page?: number
+
+  @IsOptional()
+  @Type(() => Number)
+  @IsInt()
+  @Min(1)
+  pageSize?: number
+}
