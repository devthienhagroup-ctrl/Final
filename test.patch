+  `email` VARCHAR(120) NULL,
+  `need` VARCHAR(200) NULL,
+  `note` TEXT NULL,
+  `ip_address` VARCHAR(64) NOT NULL,
+  `user_agent` VARCHAR(500) NULL,
+  `status` VARCHAR(30) NOT NULL DEFAULT 'new',
