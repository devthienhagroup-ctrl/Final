 function readCartCount(): number {
   try {
     const raw = localStorage.getItem(COURSE_CART_KEY);
     const arr = raw ? (JSON.parse(raw) as unknown) : [];
     return Array.isArray(arr) ? arr.length : 0;
   } catch {
