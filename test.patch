+import { clearStudentSession, seedStudentSession } from '../studentAuth'
+import './pages.css'
+
+const courses = [
+  { id: 1, title: 'Giải phẫu da chuyên sâu', progress: 65 },
+  { id: 2, title: 'Phác đồ trị mụn chuẩn spa', progress: 30 },
+  { id: 3, title: 'Xử lý tăng sắc tố an toàn', progress: 80 },
+]
+
+export function LearningSpacePage() {
+  return (
+    <main className="page-wrap">
+      <header className="top-bar">
+        <h1>Không gian học tập</h1>
+        <p>Theo dõi tiến độ khóa học và tiếp tục bài học đang dang dở.</p>
+      </header>
+
+      <section className="card-grid">
+        {courses.map((course) => (
+          <article key={course.id} className="course-card">
+            <h2>{course.title}</h2>
+            <p>Tiến độ: {course.progress}%</p>
+          </article>
+        ))}
+      </section>
+
+      <section className="dev-tools">
+        <p>Kiểm tra quyền truy cập đầy đủ:</p>
+        <div className="btn-row">
+          <button
+            type="button"
+            onClick={() => {
+              seedStudentSession()
+              window.location.href = '/student/learning-space'
+            }}
+          >
+            Cấp quyền đầy đủ
+          </button>
+          <button
+            type="button"
+            onClick={() => {
+              clearStudentSession()
+              window.location.href = '/student/learning-space'
+            }}
+          >
+            Xóa quyền (đá về 403)
+          </button>
+        </div>
+      </section>
+    </main>
+  )
+}
