-    if (seen.has(v)) return "[Circular]";
-    seen.add(v);
-
-    const keys = Object.keys(v).sort();
-    const out: Record<string, any> = {};
-    for (const k of keys) {
-      const next = v[k];
-      if (typeof next === "undefined") continue;
