 function sortLessons<T extends { id: number; order?: number }>(lessons: T[]): T[] {
   return [...lessons].sort((a, b) => {
     const ao = a.order ?? 0;
     const bo = b.order ?? 0;
     if (ao !== bo) return ao - bo;
     return a.id - b.id;
   });
 }

