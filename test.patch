+      name: row.name.trim() || undefined,
+      phone: row.phone.trim() || undefined,
+      birthDate: row.birthDate || undefined,
+      gender: row.gender || undefined,
+      address: row.address.trim() || undefined,
+      isActive: row.isActive,
+    })
