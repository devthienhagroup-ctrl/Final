 import { Navigate, Outlet, Route, Routes, useLocation } from 'react-router-dom'
 import { useAuth } from './auth'
 import { AdminDashboardPage } from '../pages/admin/AdminDashboardPage'
 import { LoginPage } from '../pages/admin/LoginPage'
