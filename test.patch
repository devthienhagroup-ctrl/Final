+import React, { useEffect, useMemo, useState } from "react";
+import { useAuth } from "../../app/auth";
+import { adminListContactInquiries, adminReplyContactInquiry, type ContactInquiry } from "../api/contactInquiries.api";
+
+export function ContactInquiriesPage() {
+  const { token } = useAuth();
+  const [items, setItems] = useState<ContactInquiry[]>([]);
+  const [loading, setLoading] = useState(false);
+  const [status, setStatus] = useState<string>("");
+  const [search, setSearch] = useState("");
+  const [selected, setSelected] = useState<ContactInquiry | null>(null);
+  const [subject, setSubject] = useState("Phản hồi từ AYANAVITA");
+  const [content, setContent] = useState("");
+
+  const query = useMemo(() => {
+    const params: Record<string, string> = {};
+    if (status) params.status = status;
+    if (search.trim()) params.search = search.trim();
+    return params;
+  }, [search, status]);
+
+  const loadData = async () => {
+    if (!token) return;
+    setLoading(true);
+    try {
+      const res = await adminListContactInquiries(token, query);
+      setItems(res.items);
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  useEffect(() => {
+    void loadData();
+  }, [token, query]);
+
+  const onReply = async () => {
+    if (!token || !selected || !subject.trim() || !content.trim()) return;
+    await adminReplyContactInquiry(token, selected.id, {
+      toEmail: selected.email || undefined,
+      subject: subject.trim(),
+      content: content.trim(),
+    });
+    setContent("");
+    await loadData();
+  };
+
+  return (
+    <div className="grid" style={{ gap: 12 }}>
+      <div className="card">
+        <div className="h1">Liên hệ khách hàng</div>
+        <div style={{ display: "flex", gap: 8, marginTop: 12 }}>
+          <input className="input" placeholder="Tìm tên/sđt/email" value={search} onChange={(e) => setSearch(e.target.value)} />
+          <select className="select" value={status} onChange={(e) => setStatus(e.target.value)}>
+            <option value="">Tất cả trạng thái</option>
+            <option value="new">Mới</option>
+            <option value="replied">Đã phản hồi</option>
+          </select>
+          <button className="btn" onClick={() => void loadData()}>{loading ? "Loading..." : "Làm mới"}</button>
+        </div>
+      </div>
+
+      <div className="card">
+        <table className="table">
+          <thead>
+            <tr>
+              <th>ID</th><th>Khách hàng</th><th>Nhu cầu</th><th>IP</th><th>Trạng thái</th><th>Ngày</th>
+            </tr>
+          </thead>
+          <tbody>
+            {items.map((it) => (
+              <tr key={it.id} onClick={() => setSelected(it)} style={{ cursor: "pointer" }}>
+                <td>{it.id}</td>
+                <td>
+                  <div>{it.name}</div>
+                  <div className="muted">{it.phone} • {it.email || "-"}</div>
+                </td>
+                <td>{it.need || "-"}</td>
+                <td>{it.ipAddress}</td>
+                <td>{it.status}</td>
+                <td>{new Date(it.createdAt).toLocaleString("vi-VN")}</td>
+              </tr>
+            ))}
+          </tbody>
+        </table>
+      </div>
+
+      {selected ? (
+        <div className="card" style={{ display: "grid", gap: 8 }}>
+          <div className="h2">Phản hồi liên hệ #{selected.id}</div>
+          <div className="muted">{selected.note || "(Không có ghi chú)"}</div>
+          <input className="input" value={subject} onChange={(e) => setSubject(e.target.value)} placeholder="Tiêu đề email" />
+          <textarea className="input" rows={5} value={content} onChange={(e) => setContent(e.target.value)} placeholder="Nội dung phản hồi" />
+          <button className="btn btn-primary" onClick={() => void onReply()}>Gửi phản hồi email</button>
+          <div>
+            <div className="muted">Lịch sử phản hồi</div>
+            {selected.replies.map((r) => (
+              <div key={r.id} className="muted">• {new Date(r.createdAt).toLocaleString("vi-VN")} - {r.staffEmail || "staff"}: {r.subject}</div>
+            ))}
+          </div>
+        </div>
+      ) : null}
+    </div>
+  );
+}
