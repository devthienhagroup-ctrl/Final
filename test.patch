+.status-page {
+  min-height: 100vh;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: 24px;
+  background:
+    radial-gradient(900px 500px at 0% 0%, rgba(79, 70, 229, 0.16), transparent 60%),
+    radial-gradient(700px 380px at 100% 100%, rgba(14, 165, 233, 0.14), transparent 60%),
