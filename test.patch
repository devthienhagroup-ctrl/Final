 }

 function toMinuteLabel(raw?: string | null) {
   if (!raw) return "-";
   const n = Number(String(raw).replace(/[^0-9.]/g, ""));
   if (!Number.isFinite(n) || n <= 0) return "-";
   return `${Math.round(n * 60)} phút`;
 }

