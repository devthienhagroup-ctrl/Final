-  const key = section?.key || "unknown";
-
-  const locInfo = useMemo(() => (section ? pickLocale(section, locale) || null : null), [section, locale]);
-  const effectiveData = useMemo(() => locInfo?.draftData ?? locInfo?.publishedData ?? {}, [locInfo]);
-
