diff --git a/student/src/studentAuth.ts b/student/src/studentAuth.ts
new file mode 100644
index 0000000000000000000000000000000000000000..968c510c41bf9855b23583ebbd0faefe94ff1a65
--- /dev/null
+++ b/student/src/studentAuth.ts
@@ -0,0 +1,48 @@
+export type StudentSession = {
+  token: string
+  permissions: string[]
+}
+
+const STORAGE_KEY = 'student_session'
+
+const DEFAULT_SESSION: StudentSession = {
+  token: 'student-token-dev',
+  permissions: ['my_courses.read'],
+}
+
+function readSession(): StudentSession | null {
+  const raw = localStorage.getItem(STORAGE_KEY)
+
+  if (!raw) {
+    localStorage.setItem(STORAGE_KEY, JSON.stringify(DEFAULT_SESSION))
+    return DEFAULT_SESSION
+  }
+
+  try {
+    const parsed = JSON.parse(raw) as StudentSession
+    if (!parsed.token || !Array.isArray(parsed.permissions)) {
+      return null
+    }
+    return parsed
+  } catch {
+    return null
+  }
+}
+
+export function useStudentAuth() {
+  const session = readSession()
+
+  return {
+    token: session?.token ?? '',
+    permissions: session?.permissions ?? [],
+    can: (permission: string) => (session?.permissions ?? []).includes(permission),
+  }
+}
+
+export function seedStudentSession() {
+  localStorage.setItem(STORAGE_KEY, JSON.stringify(DEFAULT_SESSION))
+}
+
+export function clearStudentSession() {
+  localStorage.removeItem(STORAGE_KEY)
+}
